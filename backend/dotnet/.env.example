# Server
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5000

# Database
ConnectionStrings__DefaultConnection=Host=localhost;Database=mydb;Username=admin;Password=password

# JWT
Jwt__Secret=your-super-secret-key-change-in-production
Jwt__Issuer=multi-backend-app
Jwt__Audience=multi-backend-app-users

# Email (SMTP)
Email__Host=smtp.ethereal.email
Email__Port=587
Email__Username=your-email
Email__Password=your-password